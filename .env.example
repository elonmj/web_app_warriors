# Admin dashboard password (change in production!)
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie (change in production!)
ADMIN_SESSION_SECRET=

# Bearer token required to call /api/cron/auto-resolve
CRON_SECRET=

# Realtime Database URL used by firebase-admin (server-only). Defaults to
# the production instance if unset — override for a different environment.
FIREBASE_DATABASE_URL=

# Optional: stringified service account JSON, only needed on hosts outside
# Google Cloud (e.g. Vercel) where Application Default Credentials aren't
# available. On Firebase Hosting / local dev with `gcloud auth
# application-default login`, leave this unset.
FIREBASE_SERVICE_ACCOUNT_JSON=
